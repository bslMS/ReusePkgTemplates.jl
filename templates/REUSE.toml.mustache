# REUSE.toml
# Part of {{{PKG}}}

version = 1

[[annotations]]
path = [
    ".gitattributes",
    ".gitignore",
    ".github/**",
    ".vscode/**",
    ".licensing/**",
    ".drone.star",
    ".JuliaFormatter.toml",
    ".codecov.yml",
    ".*.yml",
    "CITATION.bib",
    "CODEOWNERS",
    "Project.toml",
    "Manifest.toml",
    "docs/make.jl",
    "docs/Project.toml",
    "docs/Manifest.toml",
    "test/Project.toml",
    "test/Manifest.toml",
]
precedence = "closest"
SPDX-FileCopyrightText = "{{{YEAR}}} {{{AUTHORS}}}"
SPDX-License-Identifier = "{{{INFRASTRUCTURE_LICENSE}}}"
SPDX-FileComment = "This file is generated, project metadata, or other project infrastructure."

[[annotations]]
path = [
    "docs/src/assets/**",
]
precedence = "closest"
SPDX-FileCopyrightText = "{{{YEAR}}} {{{AUTHORS}}}"
SPDX-License-Identifier = "{{{DOCS_ASSETS_LICENSE}}}"
SPDX-FileComment = "This file is content for the documentation."

[[annotations]]
path = [
    "{{{README}}}",
    "docs/*.md",
    "docs/src/**/*.md",
]
precedence = "closest"
SPDX-FileCopyrightText = "{{{YEAR}}} {{{AUTHORS}}}"
SPDX-License-Identifier = "{{{DOCS_LICENSE}}}"
SPDX-FileComment = "This file is a documentation source file."
